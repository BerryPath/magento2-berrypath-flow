{
    "name": "berrypath/magento2-berrypath-flow",
    "description": "BerryPath Flow widget integration for Magento 2.",
    "type": "magento2-module",
    "version": "1.0.5",
    "license": "MIT",
    "support": {
        "source": "https://github.com/BerryPath/magento2-berrypath-flow"
    },
    "require": {
        "php": ">=8.1",
        "berrypath/magento2-berrypath-product-feed": "^1.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "BerryPath\\Flow\\": ""
        }
    },
    "suggest": {
        "berrypath/magento2-berrypath-flow-hyva-compat": "Hyva compatibility for BerryPath Flow."
    }
}
